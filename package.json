{
  "name": "rootcode",
  "version": "0.1.0",
  "description": "A local CLI coding agent powered by Ollama — like Claude Code, but running entirely on your machine.",
  "type": "module",
  "bin": {
    "rootcode": "bin/rootcode.js"
  },
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsc",
    "start": "node bin/rootcode.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "coding-agent",
    "ollama",
    "llm",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-highlight": "^2.1.11",
    "diff": "^9.0.0",
    "ink": "^7.1.0",
    "ollama": "^0.6.3",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
